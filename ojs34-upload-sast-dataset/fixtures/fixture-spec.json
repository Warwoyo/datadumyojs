      "submitter_user_id": 6,
      "title": "A Reproducible Pipeline for Streaming Log Analytics at Scale",
      "abstract": "Operational logs are a primary signal for diagnosing distributed systems, yet pipelines that process them are often ad hoc and hard to reproduce.\nWe present a modular pipeline that combines schema-on-read ingestion with incremental aggregation, and evaluate it on three public workloads.\nResults indicate consistent latency under sustained load and a clear path to horizontal scaling.",
      "keywords": ["stream processing", "observability", "reproducibility", "distributed systems"],
      "authors": [
        { "given": "Ravi", "family": "Kumar", "affiliation": "Indian Institute of Technology Delhi", "country": "IN", "email": "rkumar@example.org", "seq": 1 },
        { "given": "Anna", "family": "Fischer", "affiliation": "Technical University of Munich", "country": "DE", "email": "afischer@example.org", "seq": 2 }
      ],
